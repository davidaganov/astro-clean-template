---
import Head from "@/components/general/Head.astro"
import Header from "@/components/general/Header.astro"
import Footer from "@/components/general/Footer.astro"
import "@/assets/styles/main.css"

const { title = "Astro Clean", description = "" } = Astro.props
---

<html lang="en">
  <Head
    title={title}
    description={description}
  />

  <body class="subpage">
    <div class="wrapper">
      <Header />
      <main class="main subpage__main">
        <slot />
      </main>
      <Footer class="footer" />
    </div>

    <script is:inline type="module" src="/assets/script/main.js"></script>
  </body>
</html>

<style is:global>
  .subpage {
    background: var(--color-bg);
  }

  .subpage__main {
    padding-block: 32px 48px;
  }
</style>
