{
  "name": "astro-clean-template",
  "version": "1.0.0",
  "description": "Astro starter for static sites with handoff-oriented output: readable HTML, one CSS bundle, stable script paths under dist/, and multiple root layouts.",
  "type": "module",
  "keywords": [
    "astro",
    "astro-template",
    "static-site",
    "vite",
    "handoff",
    "html",
    "css"
  ],
  "homepage": "https://github.com/davidaganov/astro-clean-template#readme",
  "bugs": {
    "url": "https://github.com/davidaganov/astro-clean-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidaganov/astro-clean-template.git"
  },
  "author": {
    "name": "David Aganov",
    "url": "https://github.com/davidaganov"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clean": "node scripts/starter.js clean",
    "restore": "node scripts/starter.js restore",
    "dev": "astro dev",
    "build": "astro build",
    "build:prod": "cross-env PROD_BUILD=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "astro": "^6.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
