---
import AboutLayout from "@/layouts/AboutLayout.astro"
---

<AboutLayout
  title="About this template"
  description="Second root layout (SubpageLayout): same global CSS and client entry pattern, different page shell."
>
  <article class="article">
    <header class="article__header">
      <h1 class="article__title">Inner page layout</h1>
      <p class="article__meta">
        Built with SubpageLayout.astro — an alternate root document for non-home routes
      </p>
    </header>
    <div class="article__body">
      <p>
        This route uses <code>SubpageLayout.astro</code> as the root template instead of <code>
          Layout.astro
        </code>. Both layouts import the same global stylesheet and the same client entry (<code>
          src/assets/script/main.js
        </code>), but you can vary the outer markup—wrapper classes, spacing, or structure—for pages
        that should not share the home shell.
      </p>
      <p>
        Client scripts live under <code>src/assets/script/</code> and are copied to <code>
          dist/assets/script/
        </code> on
        <code>npm run build</code>, or bundled into a single minified <code>main.js</code> on
        <code>npm run build:prod</code> (see README).
      </p>
      <p>
        <a href="/">← Back to home</a>
      </p>
    </div>
  </article>
</AboutLayout>

<style is:global>
  .article {
    max-width: 38rem;
    margin-inline: auto;
  }

  .article__header {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  .article__title {
    margin: 0 0 8px;
    font-size: clamp(1.5rem, 3vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
  }

  .article__meta {
    margin: 0;
    font-size: 14px;
    color: var(--color-muted);
  }

  .article__body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-muted);

    & p {
      margin: 0 0 1rem;
    }

    & p:last-child {
      margin-bottom: 0;
      margin-top: 1.5rem;
    }

    & code {
      font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
      font-size: 0.88em;
      padding: 0.12em 0.4em;
      border-radius: 4px;
      background: var(--color-accent-soft);
      color: var(--color-accent-hover);
    }

    & a {
      font-weight: 500;
      color: var(--color-accent);
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
