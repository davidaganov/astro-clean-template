---
import { Picture } from "astro:assets"
import type { ImageMetadata } from "astro"

export interface Props {
  image: ImageMetadata
  alt: string
  /**
   * Encoded variants (e.g. AVIF + WebP). The `<img>` fallback is a separate optimized file (often PNG/JPEG),
   * so you typically get **3 files total** for a PNG source: `formats.length` + fallback.
   */
  formats?: ("avif" | "webp" | "png" | "jpeg")[]
  quality?: number
  width?: number
  height?: number
  loading?: "lazy" | "eager"
  decoding?: "async" | "auto" | "sync"
  class?: string
}

const {
  image,
  alt,
  formats = ["avif", "webp"],
  quality,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  class: className
} = Astro.props
---

<div class={`image-card ${className ?? ""}`}>
  <div class="image-card__media">
    <Picture
      src={image}
      alt={alt}
      formats={formats}
      quality={quality}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      class="image-card__img"
    />
  </div>
</div>

<style is:global>
  .image-card {
    width: 100%;
    max-width: 296px;
  }

  .image-card__media {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .image-card__img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }
</style>
