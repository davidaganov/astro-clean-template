---
import ImageCard from "@/components/base/ImageCard.astro"
import demoImage from "@/assets/images/demo.jpg"
---

<section
  class="image-demo"
  aria-labelledby="image-demo-title"
>
  <div class="container">
    <h2
      id="image-demo-title"
      class="image-demo__title"
    >
      astro:assets — <code>Picture</code>
    </h2>
    <p class="image-demo__lead">
      Two <code>&lt;source&gt;</code> encodings (AVIF, WebP) plus one optimized <code>
        &lt;img&gt;
      </code> fallback (PNG here) — three files in <code>dist/assets/images</code> for this demo.
    </p>
    <div class="image-demo__row">
      <ImageCard
        image={demoImage}
        alt="Demo thumbnail"
        formats={["avif", "webp"]}
        width={296}
        height={296}
      />
    </div>
  </div>
</section>

<style is:global>
  .image-demo {
    padding: 40px 0 48px;
    border-top: 1px solid var(--color-border);
  }

  .image-demo__title {
    margin: 0 0 8px;
    font-size: 1.125rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: -0.02em;
    color: var(--color-text);

    & code {
      font-family: ui-monospace, monospace;
      font-weight: 500;
      font-size: 0.95em;
    }
  }

  .image-demo__lead {
    margin: 0 0 24px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-muted);
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;

    & code {
      font-family: ui-monospace, monospace;
      font-size: 0.9em;
      padding: 0.1em 0.35em;
      border-radius: 4px;
      background: var(--color-accent-soft);
      color: var(--color-accent-hover);
    }
  }

  .image-demo__row {
    display: flex;
    justify-content: center;
  }
</style>
