---
import Head from "@/components/general/Head.astro"
import Header from "@/components/general/Header.astro"
import Footer from "@/components/general/Footer.astro"
import "@/assets/styles/main.css"

const { title = "Astro Clean", description = "" } = Astro.props
---

<html lang="en">
  <Head
    title={title}
    description={description}
  />

  <body>
    <div class="background-grid">
      <svg
        class="background-grid__svg"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <pattern
            width="60"
            height="60"
            patternUnits="userSpaceOnUse"
            id="app-grid"
          >
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke-width="1.2"
              class="grid-line"
            >
            </path>
          </pattern>
          <radialGradient
            cx="50%"
            cy="50%"
            r="50%"
            id="app-vignette"
          >
            <stop
              offset="0%"
              stop-color="var(--color-bg)"
              stop-opacity="0"
            >
            </stop>
            <stop
              offset="90%"
              stop-color="var(--color-bg)"
              stop-opacity="0.85"
            >
            </stop>
            <stop
              offset="100%"
              stop-color="var(--color-bg)"
              stop-opacity="1"
            >
            </stop>
          </radialGradient>
        </defs>
        <rect
          width="100%"
          height="100%"
          fill="url(#app-grid)"
        >
        </rect>
        <rect
          width="100%"
          height="100%"
          fill="url(#app-vignette)"
        >
        </rect>
      </svg>
    </div>

    <div class="wrapper">
      <Header />
      <main class="main">
        <slot />
      </main>
      <Footer class="footer" />
    </div>

    <script is:inline type="module" src="/assets/script/main.js"></script>
  </body>
</html>

<style is:global>
  .background-grid {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .background-grid__svg {
    width: 100%;
    height: 100%;
  }

  .grid-line {
    stroke: rgba(184, 126, 239, 0.1);
  }

  .wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  .main {
    flex: 1;
  }

  .footer {
    margin-top: auto;
  }
</style>
