---
// @webstack:imports
import UiButton from "@/components/ui/UiButton.astro"

const getStartedLabel = "Get Started"
const readMoreLabel = "Read More"
---

<div class="actions">
  <UiButton type="primary" class="actions__btn">
    {getStartedLabel}
  </UiButton>
  <UiButton type="outline" href="/about" class="actions__btn">
    {readMoreLabel}
  </UiButton>
</div>

<style>
  .actions {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: 8px;
    margin-top: 32px;
    max-width: 180px;
  }

  .actions__btn {
    width: 100%;
  }

  @media (min-width: 768px) {
    .actions {
      flex-direction: row;
      gap: 16px;
      margin-top: 48px;
      max-width: 340px;
    }
  }
</style>
