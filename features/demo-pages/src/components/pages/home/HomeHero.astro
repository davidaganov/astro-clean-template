---
const version = "1.0.2"
// @webstack:imports

const badge = `v${version}`
const title = "Astro Clean"
const subtitle = "Template"
const description = "A modern Astro starter template with dark theme and violet accents."
---

<div class="hero">
  <span class="hero__badge">
    {badge}
  </span>

  <div class="hero__titles">
    <h1 class="hero__title">{title}</h1>
    <h2 class="hero__subtitle">{subtitle}</h2>
  </div>

  <p class="hero__description">
    {description}
  </p>
</div>

<style>
  .hero {
    text-align: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    padding: 4px 16px;
    background: var(--color-primary-10);
    border: 1px solid var(--color-primary-20);
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
  }

  .hero__titles {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 12px;
  }

  .hero__title {
    margin: 0;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .hero__subtitle {
    margin: 0;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-primary);
  }

  .hero__description {
    margin: 16px 0 0;
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 65%;
    margin-inline: auto;
  }
</style>
