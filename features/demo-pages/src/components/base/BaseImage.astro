---
import { Picture } from "astro:assets"
import type { ImageMetadata } from "astro"

export interface Props {
  image: ImageMetadata
  alt: string
  formats?: ("avif" | "webp" | "png" | "jpeg")[]
  quality?: number
  width?: number
  height?: number
  loading?: "lazy" | "eager"
  decoding?: "async" | "auto" | "sync"
  class?: string
}

const {
  image,
  alt,
  formats = ["avif", "webp"],
  quality,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  class: className
} = Astro.props
---

<div class={`base-image ${className ?? ""}`}>
  <div class="base-image__media">
    <Picture
      src={image}
      alt={alt}
      formats={formats}
      quality={quality}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      class="base-image__img"
    />
  </div>
</div>

<style is:global>
  .base-image {
    width: 100%;
    max-width: 296px;
  }

  .base-image__media {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .base-image__img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }
</style>
